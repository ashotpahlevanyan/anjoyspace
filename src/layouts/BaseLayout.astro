---
import '../styles/global.scss';
import { buildRootCss } from '../lib/theme';
import { DEFAULT_LANG } from '../lib/i18n';
import type { Localized } from '../lib/i18n';
import SiteNav, { type NavLink } from '../components/SiteNav.tsx';
import SiteFooter from '../components/SiteFooter.astro';
import ContactModal from '../components/ContactModal.tsx';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  pageClass: string;
  accentVars?: string;
  /** Open Graph type (default "website"; use "article" for blog posts). */
  ogType?: string;
  /** Absolute or root-relative image URL for social cards. */
  ogImage?: string;
  nav: {
    breadcrumb?: { ru: string; en: string };
    navLinks: NavLink[];
    menuLinks: NavLink[];
    cta?: { ru: string; en: string };
  };
  footer?: {
    variant: 'full' | 'simple';
    copyright?: Localized;
    links?: { label: Localized; href: string }[];
  };
  /** Render the contact modal island on this page (any [data-contact] trigger). */
  contact?: boolean;
}

import siteData from '../content/settings/site.json';
const {
  title,
  description,
  pageClass,
  accentVars,
  ogType = 'website',
  ogImage,
  nav,
  footer = { variant: 'full' },
  contact = true,
} = Astro.props;
const rootCss = buildRootCss();

// Canonical + social URLs from the configured site origin.
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://anjoy.space').href;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site ?? 'https://anjoy.space').href : undefined;
---

<!doctype html>
<html lang={DEFAULT_LANG} id="htmlRoot">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="yandex-verification" content="4a9e925667ba8d95" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Anjoy Space" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <style is:global set:html={rootCss}></style>

    <!-- Yandex.Metrica (counter 110564858) — only on the production domain so
         dev / preview / localhost traffic doesn't pollute the stats. -->
    <script type="text/javascript" is:inline>
      (function () {
        if (!/(^|\.)anjoy\.space$/.test(location.hostname)) return;
        (function (m, e, t, r, i, k, a) {
          m[i] = m[i] || function () { (m[i].a = m[i].a || []).push(arguments); };
          m[i].l = 1 * new Date();
          for (var j = 0; j < document.scripts.length; j++) { if (document.scripts[j].src === r) { return; } }
          k = e.createElement(t); a = e.getElementsByTagName(t)[0]; k.async = 1; k.src = r; a.parentNode.insertBefore(k, a);
        })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=110564858', 'ym');
        ym(110564858, 'init', { ssr: true, webvisor: true, clickmap: true, ecommerce: 'dataLayer', accurateTrackBounce: true, trackLinks: true });
      })();
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/110564858" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrica -->

    <!-- Google Analytics 4 (G-QNCQES8F55) — production domain only. -->
    <script is:inline>
      (function () {
        if (!/(^|\.)anjoy\.space$/.test(location.hostname)) return;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-QNCQES8F55';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-QNCQES8F55');
      })();
    </script>
    <!-- /Google Analytics 4 -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem('anjoy_lang') || 'ru';
          document.documentElement.setAttribute('lang', l);
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // First-touch attribution: capture UTM params on landing, then attach
      // them (+ referrer) to every /api/lead submission so leads are traceable
      // to a campaign in the Telegram alert.
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          var utm = {};
          ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach(function (k) {
            var v = p.get(k);
            if (v) utm[k] = v;
          });
          if (Object.keys(utm).length && !sessionStorage.getItem('anjoy_utm')) {
            sessionStorage.setItem('anjoy_utm', JSON.stringify(utm));
          }
        } catch (e) {}

        var orig = window.fetch;
        window.fetch = function (url, opts) {
          try {
            if (typeof url === 'string' && url.indexOf('/api/lead') !== -1 && opts && opts.method === 'POST' && typeof opts.body === 'string') {
              var utm = JSON.parse(sessionStorage.getItem('anjoy_utm') || '{}');
              var body = JSON.parse(opts.body);
              var tag = [utm.utm_source, utm.utm_medium, utm.utm_campaign].filter(Boolean).join(' / ');
              if (tag && !body.utm) body.utm = tag;
              if (!body.referrer && document.referrer) body.referrer = document.referrer;
              opts.body = JSON.stringify(body);
            }
          } catch (e) {}
          return orig.apply(this, arguments);
        };
      })();
    </script>
  </head>
  <body>
    <SiteNav
      client:load
      brandName={siteData.brandName}
      brandSuffix={siteData.brandSuffix}
      breadcrumb={nav.breadcrumb}
      navLinks={nav.navLinks}
      menuLinks={nav.menuLinks}
      cta={nav.cta}
    />

    <main class={pageClass} style={accentVars}>
      <slot />
    </main>

    <SiteFooter variant={footer.variant} copyright={footer.copyright} links={footer.links} />

    {contact && <ContactModal client:idle />}

    <a class="side-cta" href="/#retreats" data-contact aria-label="Book a retreat">
      <svg class="side-cta__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
        <path d="M16 2v4M8 2v4M3 10h18M9 16l2 2 4-4"></path>
      </svg>
      <span class="side-cta__label">
        <span data-lang="ru">Записаться на ретрит</span>
        <span data-lang="en">Book a retreat</span>
      </span>
    </a>

    <div class="chat-fab">
      <a class="chat-btn chat-wa" href="https://wa.me/79151593376?text=Здравствуйте!%20Хочу%20узнать%20о%20ретритах%20Anjoy%20Space." target="_blank" rel="noopener" aria-label="WhatsApp">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.892c0 2.096.549 4.142 1.595 5.945L0 24l6.335-1.652a11.882 11.882 0 005.667 1.443h.005c6.585 0 11.946-5.359 11.949-11.893a11.821 11.821 0 00-3.481-8.449"/></svg>
      </a>
      <a class="chat-btn chat-tg" href="https://t.me/ovakimianani?text=Здравствуйте!%20Хочу%20узнать%20о%20ретритах%20Anjoy%20Space." target="_blank" rel="noopener" aria-label="Telegram">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
    </div>

    <button id="scrollTopBtn" class="scroll-top" type="button" aria-label="Back to top">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5M5 12l7-7 7 7"></path>
      </svg>
    </button>
    <script is:inline>
      (function () {
        var btn = document.getElementById('scrollTopBtn');
        if (!btn) return;
        var toggle = function () {
          btn.classList.toggle('visible', window.scrollY > 500);
        };
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        window.addEventListener('scroll', toggle, { passive: true });
        toggle();
      })();
    </script>

    <script is:inline>
      // Mobile "Book a retreat" CTA: collapsed to an icon on the right edge.
      // First tap expands to reveal the label; second tap performs the action
      // (the [data-contact] modal handler on it). Auto-collapses after 4s of
      // inactivity, and a tap outside collapses it. Desktop is untouched: the
      // media query only matches <=600px, so on wider screens the click falls
      // straight through to the normal one-tap behaviour.
      (function () {
        var cta = document.querySelector('.side-cta');
        if (!cta) return;
        var mq = window.matchMedia('(max-width: 600px)');
        var timer;
        var collapse = function () { cta.classList.remove('is-expanded'); };
        var expand = function () {
          cta.classList.add('is-expanded');
          clearTimeout(timer);
          timer = setTimeout(collapse, 4000);
        };
        // Capture phase so this runs BEFORE the ContactModal click listener.
        document.addEventListener(
          'click',
          function (e) {
            if (!mq.matches) return; // desktop: leave the CTA one-tap
            if (!cta.contains(e.target)) { collapse(); return; }
            if (!cta.classList.contains('is-expanded')) {
              // first tap: reveal the label, swallow the click
              e.preventDefault();
              e.stopPropagation();
              expand();
            } else {
              // second tap: let it through to book; drop the collapse timer
              clearTimeout(timer);
            }
          },
          true,
        );
        // If we shrink to mobile, start collapsed.
        mq.addEventListener && mq.addEventListener('change', collapse);
      })();
    </script>

    <script is:inline>
      // Language toggle for attributes/elements CSS can't switch (input
      // placeholders, <option> text). Elements carry data-ph-ru/data-ph-en
      // (placeholder) or data-t-ru/data-t-en (textContent); we apply the
      // active language and re-apply when <html lang> changes or React
      // islands hydrate. rAF-debounced.
      (function () {
        var html = document.documentElement;
        var lang = function () { return html.getAttribute('lang') || 'ru'; };
        var apply = function () {
          var l = lang();
          document.querySelectorAll('[data-ph-' + l + ']').forEach(function (el) {
            var v = el.getAttribute('data-ph-' + l);
            if (el.getAttribute('placeholder') !== v) el.setAttribute('placeholder', v);
          });
          // Only write when the text actually differs. Assigning textContent
          // always replaces the child text node, which the body MutationObserver
          // below sees as a childList change and re-schedules apply() — an
          // every-frame loop that froze <select> dropdowns (e.g. Lila's format).
          document.querySelectorAll('[data-t-' + l + ']').forEach(function (el) {
            var v = el.getAttribute('data-t-' + l);
            if (el.textContent !== v) el.textContent = v;
          });
        };
        var scheduled = false;
        var schedule = function () {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(function () { scheduled = false; apply(); });
        };
        apply();
        new MutationObserver(schedule).observe(html, { attributes: true, attributeFilter: ['lang'] });
        new MutationObserver(schedule).observe(document.body, { childList: true, subtree: true });
      })();

      (function () {
        var els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        var obs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry, i) {
              if (entry.isIntersecting) {
                setTimeout(function () {
                  entry.target.classList.add('visible');
                }, i * 70);
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08 },
        );
        els.forEach(function (el) {
          obs.observe(el);
        });
      })();
    </script>
    <Analytics />
  </body>
</html>
