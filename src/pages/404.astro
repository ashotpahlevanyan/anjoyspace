---
import { buildRootCss } from '../lib/theme';
const rootCss = buildRootCss();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page not found — anjoy.space</title>
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400&family=DM+Sans:wght@300;400&family=DM+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />
    <style is:global set:html={rootCss}></style>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--night); color: var(--parchment);
        font-family: var(--font-sans);
        min-height: 100vh; display: grid; place-items: center;
        text-align: center; padding: 2rem;
      }
      .eyebrow {
        font-family: var(--font-mono); font-size: 0.7rem;
        letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
        margin-bottom: 1rem; display: block;
      }
      h1 {
        font-family: var(--font-serif); font-weight: 300;
        font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 1rem;
      }
      h1 em { font-style: italic; color: var(--gold); }
      p { color: var(--parchment-dim); font-weight: 300; margin: 0 auto 2rem; max-width: 420px; }
      a {
        display: inline-block; font-size: 0.78rem; font-weight: 500;
        letter-spacing: 0.16em; text-transform: uppercase; color: var(--night);
        background: var(--gold); padding: 1rem 2.2rem; text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div>
      <span class="eyebrow">404</span>
      <h1>This path led <em>nowhere</em></h1>
      <p>Even the best journeys sometimes take a wrong turn. Let's bring you back to stillness.</p>
      <a href="/">Return Home</a>
    </div>
  </body>
</html>
