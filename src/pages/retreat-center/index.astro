<style is:global>
  /* Lori canyon vision animation — ambient, subtle, reduced-motion-safe. */
  .site-visual.lori { background: linear-gradient(180deg, #0d1117 0%, #0c1a16 100%); }
  .lori-svg { width: 100%; height: 100%; display: block; }
  .lori-drop { filter: drop-shadow(0 0 5px rgba(226, 201, 138, 0.85)); }
  @media (prefers-reduced-motion: no-preference) {
    .lori-mist1 { animation: loriDriftA 26s ease-in-out infinite alternate; }
    .lori-mist2 { animation: loriDriftB 32s ease-in-out infinite alternate; }
    .lori-sun { transform-box: fill-box; transform-origin: center; animation: loriBreathe 10s ease-in-out infinite; }
    .lori-star { animation: loriTwinkle var(--d, 5s) ease-in-out infinite; }
  }
  @keyframes loriDriftA { to { transform: translateX(34px); } }
  @keyframes loriDriftB { to { transform: translateX(-34px); } }
  @keyframes loriBreathe { 0%, 100% { transform: scale(1); opacity: 0.92; } 50% { transform: scale(1.03); opacity: 1; } }
  @keyframes loriTwinkle { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.9; } }

  /* Vision scenes (architecture + Lake Sevan) */
  .vision-scenes { text-align: center; }
  .vscenes-head { max-width: 640px; margin: 0 auto 2.6rem; }
  .scene-banner, .scene-panel { position: relative; overflow: hidden; border-radius: 4px; border: 1px solid var(--border); background: #0d1117; }
  .scene-banner { aspect-ratio: 16 / 6; margin: 0 auto var(--gap); }
  .scene-panel { aspect-ratio: 16 / 9; max-width: 920px; margin: 0 auto; }
  .scene-cap { position: absolute; left: 0; right: 0; bottom: 0; text-align: left; padding: 2rem 1.8rem 1.2rem; background: linear-gradient(to top, rgba(13, 17, 23, 0.85), transparent); }
  .scene-cap .tag { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); }
  .scene-cap p { font-size: 0.85rem; color: var(--parchment-dim); margin-top: 0.3rem; max-width: 540px; }
  .lori-win rect { filter: drop-shadow(0 0 6px rgba(242, 221, 163, 0.75)); }
  .lori-shimmer { transform-box: fill-box; transform-origin: center; }
  @media (prefers-reduced-motion: no-preference) {
    .lori-win rect { animation: loriWin var(--d, 5s) ease-in-out infinite; }
    .lori-shimmer { animation: loriShimmer 6s ease-in-out infinite; }
    .lori-ripple { animation: loriRipple var(--d, 8s) ease-in-out infinite; }
  }
  @keyframes loriWin { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
  @keyframes loriShimmer { 0%, 100% { opacity: 0.45; transform: scaleX(1); } 50% { opacity: 0.75; transform: scaleX(1.3); } }
  @keyframes loriRipple { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(14px); } }
</style>
<script is:inline>
  // Freeze the river's traveling light (SMIL) for reduced-motion users.
  (function () {
    if (!window.matchMedia || !matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var svg = document.querySelector('.lori-svg');
    if (svg && svg.pauseAnimations) svg.pauseAnimations();
  })();
</script>
