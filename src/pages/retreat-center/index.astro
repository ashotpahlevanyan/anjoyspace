          <rect x="446" y="386" width="150" height="74" /><path d="M431,386 L521,336 L611,386 Z" /><rect x="509" y="428" width="24" height="32" />
          <rect x="1004" y="386" width="150" height="74" /><path d="M989,386 L1079,336 L1169,386 Z" /><rect x="1067" y="428" width="24" height="32" />
        </g>
        <g stroke="#c9a96e" stroke-width="1.3" fill="#0e1922">
