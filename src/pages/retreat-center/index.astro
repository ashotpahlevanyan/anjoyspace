---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import T from '../../components/T.astro';
import type { NavLink } from '../../components/SiteNav.tsx';

const navLinks: NavLink[] = [
  { href: '/#retreats', label: { ru: 'Ретриты', en: 'Retreats' } },
  { href: '/teachers/', label: { ru: 'Преподаватели', en: 'Teachers' } },
  { href: '/corporate/', label: { ru: 'Командам', en: 'Teams' } },
];
const menuLinks: NavLink[] = [
  { href: '/', label: { ru: 'Главная', en: 'Home' } },
  { href: '/#retreats', label: { ru: 'Ретриты', en: 'Retreats' } },
  { href: '/teachers/', label: { ru: 'Преподаватели', en: 'Teachers' } },
  { href: '/retreat-center/', label: { ru: 'Ретрит-центр', en: 'Retreat Center' } },
  { href: '/corporate/', label: { ru: 'Для команд', en: 'For Teams' } },
];
const breadcrumb = { ru: '/ ретрит-центр', en: '/ retreat center' };
const footer = {
  variant: 'simple' as const,
  copyright: { ru: '© 2026, Anjoy Space · Проект ретрит-центра', en: '© 2026, Anjoy Space · Retreat Center Project' },
  links: [
    { label: { ru: 'Назад на anjoy.space', en: 'Back to anjoy.space' }, href: '/' },
    { label: { ru: 'Все преподаватели', en: 'All Teachers' }, href: '/teachers/' },
    { label: { ru: 'Познакомиться с Ани', en: 'Meet Ani' }, href: '/teachers/ani/' },
  ],
};

const facilities = [
  {
    img: 'fimg-1',
    symbol: '⊙',
    title: { ru: 'Главный зал для практики', en: 'Main Practice Hall' },
    body: {
      ru: 'Зал без колонн для 16+ практикующих, ориентированный на естественный свет и утренние приветствия солнцу.',
      en: 'A column-free shala built for 16+ practitioners, oriented for natural light and morning sun salutations.',
    },
  },
  {
    img: 'fimg-2',
    symbol: '☽',
    title: { ru: 'Комната нидры и тишины', en: 'Nidra & Stillness Room' },
    body: {
      ru: 'Отдельная комната с приглушённым светом для йога-нидры, звукотерапии и восстановительных практик — вдали от активных пространств.',
      en: 'A dedicated low-light room for yoga nidra, sound healing, and restorative work — separate from active practice spaces.',
    },
  },
  {
    img: 'fimg-3',
    symbol: '⬡',
    title: { ru: 'Комната кругов', en: 'Circle Room' },
    body: {
      ru: 'Камерное пространство для женских кругов, групповых диалогов и церемоний — рассадка по кругу, без «передней части» зала.',
      en: "An intimate space for women's circles, group dialogue, and ceremony — seating in the round, no front of room.",
    },
  },
  {
    img: 'fimg-4',
    symbol: '❋',
    title: { ru: 'Личные комнаты для гостей', en: 'Private Guest Quarters' },
    body: {
      ru: '12–16 индивидуально спроектированных комнат с акцентом на тишину, натуральные материалы и минимум цифровых отвлечений.',
      en: '12-16 individually designed rooms prioritizing quiet, natural materials, and minimal digital distraction.',
    },
  },
  {
    img: 'fimg-5',
    symbol: '✦',
    title: { ru: 'Общая кухня и столовая', en: 'Shared Kitchen & Dining' },
    body: {
      ru: 'Вегетарианская кухня формата farm-to-table, построенная вокруг совместных трапез как части ритма ретрита, а не второстепенной детали.',
      en: 'Farm-to-table vegetarian kitchen built around communal meals as part of the retreat rhythm, not an afterthought.',
    },
  },
  {
    img: 'fimg-6',
    symbol: '◎',
    title: { ru: 'Открытая площадка для практики', en: 'Outdoor Practice Deck' },
    body: {
      ru: 'Адаптируемое к погоде пространство под открытым небом для практики на рассвете и закате, обрамлённое окружающим ландшафтом.',
      en: 'Weather-adaptable open-air space for sunrise and sunset practice, framed by the surrounding landscape.',
    },
  },
];

const pastRuns = [
  {
    img: 'pimg-1',
    symbol: '🌿',
    meta: { ru: 'Весна 2025 · Бали', en: 'Spring 2025 · Bali' },
    title: { ru: 'В тишину', en: 'Into the Stillness' },
    location: { ru: 'Лесной приют в Убуде', en: 'Ubud Forest Sanctuary' },
    desc: {
      ru: 'Восемь дней глубокого погружения среди рисовых террас. Все места разошлись за 48 часов после открытия.',
      en: 'Eight days of deep immersion among rice terraces. Sold out within 48 hours of opening.',
    },
  },
  {
    img: 'pimg-2',
    symbol: '◎',
    meta: { ru: 'Зима 2024 · Индия', en: 'Winter 2024 · India' },
    title: { ru: 'Паломничество в Ришикеш', en: 'Rishikesh Pilgrimage' },
    location: { ru: 'Ашрам на берегу Ганги', en: 'Ganga Riverbank Ashram' },
    desc: {
      ru: 'Две недели классической практики и ежедневных речных церемоний в священный месяц Картик.',
      en: 'Two weeks of classical practice and daily river ceremonies during the sacred Kartik month.',
    },
  },
  {
    img: 'pimg-3',
    symbol: '⬡',
    meta: { ru: 'Осень 2024 · Италия', en: 'Autumn 2024 · Italy' },
    title: { ru: 'Урожай и принятие', en: 'Harvest & Surrender' },
    location: { ru: 'Валь-д’Орча, Тоскана', en: "Val d'Orcia, Tuscany" },
    desc: {
      ru: 'Кундалини, сезонная кухня и молчаливые прогулки по тосканским оливковым рощам.',
      en: 'Kundalini, seasonal cooking, and silent walking through Tuscan olive groves.',
    },
  },
  {
    img: 'pimg-4',
    symbol: '✦',
    meta: { ru: 'Лето 2024 · Греция', en: 'Summer 2024 · Greece' },
    title: { ru: 'Эгейская настройка', en: 'Aegean Alignment' },
    location: { ru: 'Вилла на скале Санторини', en: 'Santorini Clifftop Villa' },
    desc: {
      ru: 'Пранаяма на рассвете над кальдерой. Ретрит, с которого началось возвращение многих в наше сообщество.',
      en: 'Sunrise pranayama over the caldera. The retreat many of our returning community started with.',
    },
  },
  {
    img: 'pimg-5',
    symbol: '❋',
    meta: { ru: 'Весна 2024 · Португалия', en: 'Spring 2024 · Portugal' },
    title: { ru: 'Атлантическая перезагрузка', en: 'Atlantic Reset' },
    location: { ru: 'Сельский Алентежу', en: 'Alentejo Countryside' },
    desc: {
      ru: 'Дыхательные практики и погружение в холодный океан на природе Португалии.',
      en: 'Breathwork and cold ocean immersion in the Portuguese countryside.',
    },
  },
  {
    img: 'pimg-6',
    symbol: '☽',
    meta: { ru: 'Зима 2023 · Мексика', en: 'Winter 2023 · Mexico' },
    title: { ru: 'Церемония конца года', en: "Year's End Ceremony" },
    location: { ru: 'Джунгли Тулума', en: 'Tulum Jungle' },
    desc: {
      ru: 'Церемония какао и групповые дыхательные практики под пологом джунглей — первое ежегодное издание.',
      en: 'Cacao ceremony and group breathwork under the jungle canopy on the first annual edition.',
    },
  },
];
---

<BaseLayout title="Ретрит-центр — Anjoy Space" description="Ретрит-центр Anjoy Space — пространство для йога-ретритов на природе: залы для практики, проживание и питание. Уединение и тишина для глубокой практики." pageClass="page-center" nav={{ breadcrumb, navLinks, menuLinks }} footer={footer} contact={false}>
  <!-- HERO -->
  <div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="status-pill">
        <span class="status-dot"></span>
        <span data-lang="ru">В разработке · Открытие в 2027</span><span data-lang="en">In development · Opening 2027</span>
      </div>
      <T value={{ ru: 'Ретрит-центр Anjoy', en: 'The Anjoy Retreat Center' }} tag="span" class="eyebrow" />
      <T value={{ ru: 'Постоянный дом<br />для <em>глубокой практики</em>', en: 'A permanent home<br />for <em>deep practice</em>' }} tag="h1" html />
      <T
        value={{
          ru: 'Мы строим круглогодичный ретрит-центр, спроектированный с нуля для камерных погружений — не отель с занятиями йогой, а инфраструктуру, созданную специально для преображения.',
          en: "We're building a year-round retreat center designed from the ground up for small-group immersion — not a hotel with yoga classes, but infrastructure purpose-built for transformation.",
        }}
        tag="p"
        class="lede"
      />
      <div>
        <a href="#vision" class="btn-primary"><T value={{ ru: 'Читать о замысле', en: 'Read the Vision' }} /></a>
        <a href="#contact" class="btn-ghost"><T value={{ ru: 'Стать партнёром', en: 'Partner With Us' }} /></a>
      </div>
    </div>
  </div>

  <!-- VISION -->
  <section id="vision" class="vision-section">
    <div class="vision-grid">
      <div class="vision-text reveal">
        <T value={{ ru: 'Возможность', en: 'The opportunity' }} tag="span" class="eyebrow" />
        <T value={{ ru: 'Зачем <em>собственный</em> центр', en: 'Why a <em>dedicated</em> center' }} tag="h2" html />
        <T
          value={{
            ru: 'Пять лет Anjoy проводит ретриты в чужих пространствах — арендованных виллах, партнёрских йога-домах, сезонных площадках. Каждое издание распродавалось, и каждое приходилось выстраивать заново с нуля.',
            en: 'For five years, Anjoy has run retreats inside borrowed spaces — rented villas, partner yoga houses, seasonal venues. Every edition has sold out, and every edition has required rebuilding the container from scratch.',
          }}
          tag="p"
        />
        <T
          value={{
            ru: 'Собственный ретрит-центр решает это навсегда. <strong>Одна локация, спроектированная специально для камерной погружённой практики</strong> — стабильное качество, меньшая стоимость каждого ретрита со временем и база для масштабирования программ: больше ретритов в год, более длинные интенсивы и резиденции преподавателей, невозможные в арендованном пространстве.',
            en: 'A dedicated retreat center solves this permanently. <strong>One location, designed specifically for small-group immersive practice</strong> — consistent quality, lower per-retreat cost over time, and a base from which to scale programming: more retreats per year, longer-format intensives, and teacher residencies that aren\'t possible in a rented space.',
          }}
          tag="p"
          html
        />
        <T
          value={{
            ru: 'Сейчас мы подбираем варианты земли и недвижимости с ориентиром на открытие в 2027 году. Эта страница будет обновляться по мере того, как проект переходит от замысла к строительству.',
            en: 'We are currently scoping land and property options, with a target opening window of 2027. This page will be updated as the project moves from vision to ground-breaking.',
          }}
          tag="p"
        />
        <div class="vision-stats">
          <div class="vstat"><span class="number">24+</span><T value={{ ru: 'Проведённых ретритов, все с полной посадкой', en: 'Retreats run to date, fully booked' }} tag="span" class="label" /></div>
          <div class="vstat"><span class="number">94%</span><T value={{ ru: 'Доля возвращающихся участников', en: 'Returning participant rate' }} tag="span" class="label" /></div>
          <div class="vstat"><span class="number">12-16</span><T value={{ ru: 'Целевая вместимость на один цикл ретрита', en: 'Target capacity per retreat cycle' }} tag="span" class="label" /></div>
          <div class="vstat"><span class="number">2027</span><T value={{ ru: 'Целевое открытие', en: 'Target opening' }} tag="span" class="label" /></div>
        </div>
      </div>
      <div class="reveal">
        <div class="site-visual">
          <div class="gallery-symbol">⊕</div>
          <div class="site-visual-caption">
            <T value={{ ru: 'Концепт-рендер — заглушка', en: 'Concept render — placeholder' }} tag="span" class="tag" />
            <T value={{ ru: 'Визуализации места и архитектуры появятся после подтверждения объекта.', en: 'Site and architecture visuals to be added as the property is confirmed.' }} tag="p" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FACILITIES -->
  <section id="facilities">
    <SectionHeader
      eyebrow={{ ru: 'Создано для практики', en: 'Designed for practice' }}
      title={{ ru: 'Что вместит <em>центр</em>', en: 'What the center <em>will hold</em>' }}
      text={{ ru: 'Каждое пространство спланировано вокруг одного вопроса: служит ли это глубине работы или лишь комфорту пребывания? Рендеры ниже — концептуальные заглушки до финальных архитектурных планов.', en: 'Every space is planned around one question: does this serve the depth of the work, or just the comfort of the stay? Renderings below are conceptual placeholders ahead of final architectural plans.' }}
    />
    <div class="facilities-grid">
      {
        facilities.map((f) => (
          <div class="facility-card reveal">
            <div class={`facility-img ${f.img}`}><div class="gallery-symbol">{f.symbol}</div></div>
            <div class="facility-body">
              <T value={f.title} tag="h3" />
              <T value={f.body} tag="p" />
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PAST RETREATS -->
  <section id="past" class="past-section">
    <SectionHeader
      eyebrow={{ ru: 'Послужной список', en: 'Track record' }}
      title={{ ru: 'Ретриты, которые мы уже <em>провели</em>', en: "Retreats we've already <em>run</em>" }}
      text={{ ru: 'Ещё до того как центр появится, модель уже доказана — в чужих пространствах, в шести странах, всегда с аншлагом.', en: 'Before the center exists, the model has been proven — in borrowed spaces, across six countries, consistently sold out.' }}
    />
    <div class="past-grid">
      {
        pastRuns.map((p) => (
          <div class="past-card reveal">
            <div class={`past-img ${p.img}`}><div class="gallery-symbol">{p.symbol}</div></div>
            <div class="past-body">
              <T value={p.meta} tag="span" class="past-meta" />
              <T value={p.title} tag="h3" />
              <T value={p.location} tag="p" class="location" />
              <T value={p.desc} tag="p" class="desc" />
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PARTNERS -->
  <section id="network">
    <SectionHeader
      eyebrow={{ ru: 'Сеть', en: 'Network' }}
      title={{ ru: 'Часть большого <em>сообщества практики</em>', en: 'Part of a wider <em>practice community</em>' }}
      text={{ ru: 'Anjoy Space работает вместе с близкими по духу студиями и организаторами ретритов. Вот где ещё вы можете нас найти.', en: "Anjoy Space works alongside aligned studios and retreat organizers. Here's where else you can find us." }}
    />
    <div class="partners-grid">
      <div class="partner-card reveal">
        <div class="partner-top">
          <div class="partner-mark pm-1">Й</div>
          <div><h3>Yoga Berezhno</h3><span class="url">yogaberezhno</span></div>
        </div>
        <T
          value={{
            ru: 'Студия практики, построенная на принципе мягкой, внимательной работы с телом — бережный темп, чуткое внимание к ощущениям каждого практикующего и мягкий подход к развитию силы и гибкости со временем.',
            en: "A practice studio built on the principle of gentle, attentive bodywork — careful pacing, close attention to each practitioner's sensation, and a soft approach to building strength and flexibility over time.",
          }}
          tag="p"
          class="desc"
        />
        <a href="https://yogaberezhno.ru" target="_blank" rel="noopener" class="partner-link"><T value={{ ru: 'Перейти на yogaberezhno.ru →', en: 'Visit yogaberezhno.ru →' }} /></a>
      </div>
      <div class="partner-card reveal">
        <div class="partner-top">
          <div class="partner-mark pm-2">DY</div>
          <div><h3>Deep Yoga Weekend</h3><span class="url">deepyogaweekend.ru</span></div>
        </div>
        <T
          value={{
            ru: 'Ретрит выходного дня под Москвой вокруг йоги, медитации и более медленного ритма жизни — на берегу Плещеева озера, с командой сертифицированных преподавателей, включая нашу Ани Овакимян.',
            en: "A weekend retreat near Moscow built around yoga, meditation, and a slower pace of life — set on the shores of Lake Pleshcheyevo, with a rotating team of certified teachers including Anjoy's own Ani Ovakimian.",
          }}
          tag="p"
          class="desc"
        />
        <a href="https://deepyogaweekend.ru" target="_blank" rel="noopener" class="partner-link"><T value={{ ru: 'Перейти на deepyogaweekend.ru →', en: 'Visit deepyogaweekend.ru →' }} /></a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-band" id="contact">
    <span class="eyebrow" style="color:rgba(245,240,232,0.7)" data-lang="ru">Присоединяйтесь</span><span class="eyebrow" style="color:rgba(245,240,232,0.7)" data-lang="en">Get involved</span>
    <T value={{ ru: 'Помогите нам его построить', en: 'Help us build it' }} tag="h2" />
    <T value={{ ru: 'Будущий гость, преподаватель, который хочет провести здесь резиденцию, или тот, кто готов поддержать проект напрямую — мы будем рады услышать вас.', en: "Whether you're a future guest, a teacher who wants to run a residency here, or interested in supporting the project directly — we'd like to hear from you." }} tag="p" />
    <a href="mailto:hello@anjoy.space" class="btn-primary">hello@anjoy.space</a>
  </div>
</BaseLayout>
