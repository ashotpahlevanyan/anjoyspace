          <circle class="lori-star" cx="180" cy="80" r="1.3" style="--d:5s" />
          <circle class="lori-star" cx="470" cy="58" r="1.1" style="--d:6.5s" />
          <circle class="lori-star" cx="980" cy="66" r="1.1" style="--d:7s" />
          <circle class="lori-star" cx="1210" cy="52" r="1.2" style="--d:5.5s" />
          <circle class="lori-star" cx="1490" cy="86" r="1.4" style="--d:4.5s" />
        </g>
        <g class="lori-sun">
          <circle cx="1360" cy="120" r="92" fill="url(#bGlow)" />
