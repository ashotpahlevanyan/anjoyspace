            </g>

            <g class="lori-sun">
              <circle cx="1080" cy="235" r="130" fill="url(#loriSunGlow)" />
              <circle cx="1080" cy="235" r="70" fill="none" stroke="#c9a96e" stroke-width="1" opacity="0.5" />
              <circle cx="1080" cy="235" r="54" fill="none" stroke="#c9a96e" stroke-width="1" opacity="0.32" />
              <circle cx="1080" cy="235" r="38" fill="none" stroke="#c9a96e" stroke-width="1" opacity="0.5" />
              <circle cx="1080" cy="235" r="4" fill="#e2c98a" />
            </g>

            <ellipse class="lori-mist1" cx="520" cy="498" rx="470" ry="26" fill="#f5f0e8" opacity="0.05" />

            <path d="M0,470 L160,448 L320,466 L480,442 L640,464 L800,446 L960,466 L1120,446 L1280,468 L1440,450 L1440,900 L0,900 Z" fill="#24323f" opacity="0.85" />
            <path d="M0,510 L180,470 L360,516 L520,458 L680,510 L840,462 L1000,516 L1160,468 L1320,510 L1440,476 L1440,900 L0,900 Z" fill="#1a2836" />
            <path d="M0,560 L120,470 L260,528 L380,448 L500,536 L600,486 L690,556 L718,584 L742,584 L770,556 L870,490 L990,540 L1110,458 L1250,530 L1370,472 L1440,548 L1440,900 L0,900 Z" fill="#141f2b" />
            <path d="M0,560 L120,470 L260,528 L380,448 L500,536 L600,486 L690,556 L718,584 L742,584 L770,556 L870,490 L990,540 L1110,458 L1250,530 L1370,472 L1440,548" fill="none" stroke="#c9a96e" stroke-width="1" opacity="0.16" />

            <ellipse class="lori-mist2" cx="980" cy="560" rx="540" ry="30" fill="#f5f0e8" opacity="0.035" />

            <path d="M0,700 L200,636 L380,698 L540,656 L660,712 L705,770 L720,808 L735,770 L780,712 L900,660 L1080,706 L1260,640 L1440,700 L1440,900 L0,900 Z" fill="#0b131c" />

            <path d="M722 540 C708 595 744 635 718 688 C698 730 738 778 722 824 C715 860 726 882 723 900" fill="none" stroke="#c9a96e" stroke-width="7" opacity="0.16" filter="url(#loriSoft)" />
            <path d="M722 540 C708 595 744 635 718 688 C698 730 738 778 722 824 C715 860 726 882 723 900" fill="none" stroke="url(#loriRiver)" stroke-width="3" stroke-linecap="round" />
            <circle class="lori-drop" r="3.4" fill="#e2c98a">
              <animateMotion dur="11s" repeatCount="indefinite" path="M722 540 C708 595 744 635 718 688 C698 730 738 778 722 824 C715 860 726 882 723 900" />
            </circle>
          </svg>
          <div class="site-visual-caption">
            <T value={{ ru: 'Замысел · Лори и Гавар, Армения', en: 'The vision · Lori & Gavar, Armenia' }} tag="span" class="tag" />
            <T value={{ ru: 'Замысел, обретающий форму в армянских нагорьях — там, где земля уже помнит тишину.', en: 'A vision taking shape in the Armenian highlands — where the land already remembers stillness.' }} tag="p" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VISION SCENES -->
  <section class="vision-scenes">
    <div class="vscenes-head reveal">
      <T value={{ ru: 'Замысел', en: 'The vision' }} tag="span" class="eyebrow" />
      <T value={{ ru: 'Каким мы его <em>видим</em>', en: 'How we <em>picture</em> it' }} tag="h2" html />
      <T value={{ ru: 'Пока это только образ — но образ уже ясный.', en: 'Only a vision for now — but already a clear one.' }} tag="p" />
    </div>

    <!-- Fantasized architecture concept -->
    <div class="scene-banner reveal">
      <svg class="lori-svg lori-build" viewBox="0 0 1600 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
