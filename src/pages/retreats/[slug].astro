---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import T from '../../components/T.astro';
import MediaCarousel from '../../components/MediaCarousel.astro';
import type { MediaItem } from '../../components/MediaCarousel.astro';
import { pick } from '../../lib/i18n';
import type { NavLink } from '../../components/SiteNav.tsx';

export async function getStaticPaths() {
  const retreats = await getCollection('retreats', ({ data }) => !data.draft);
  return retreats.map((retreat) => ({ params: { slug: retreat.id }, props: { retreat } }));
}

const { retreat } = Astro.props;
const d = retreat.data;
const { Content } = await render(retreat);

// Build carousel item lists for the photo gallery + video reviews.
const photoItems: MediaItem[] = d.photos.map((p) => ({ type: 'image', src: p.src }));
const reviewItems: MediaItem[] = d.reviews.map((r) => {
  if (r.kind === 'vk' && r.vk) {
    const [oid, id] = r.vk.split('_');
    return {
      type: 'vk',
      embed: `https://vk.com/video_ext.php?oid=${oid}&id=${id}&hd=2`,
      poster: r.poster,
      name: r.name,
    } satisfies MediaItem;
  }
  return { type: r.kind, src: r.src, poster: r.poster, name: r.name } satisfies MediaItem;
});

const navLinks: NavLink[] = [
  { href: '/#retreats', label: { ru: 'Ретриты', en: 'Retreats' } },
  { href: '/teachers/', label: { ru: 'Преподаватели', en: 'Teachers' } },
  { href: '/retreat-center/', label: { ru: 'Центр', en: 'Center' } },
  { href: '/corporate/', label: { ru: 'Командам', en: 'Teams' } },
];
const menuLinks: NavLink[] = [
  { href: '/', label: { ru: 'Главная', en: 'Home' } },
  { href: '/#retreats', label: { ru: 'Ретриты', en: 'Retreats' } },
  { href: '/teachers/', label: { ru: 'Преподаватели', en: 'Teachers' } },
  { href: '/retreat-center/', label: { ru: 'Ретрит-центр', en: 'Retreat Center' } },
  { href: '/corporate/', label: { ru: 'Для команд', en: 'For Teams' } },
  { href: '#contact', label: { ru: 'Записаться', en: 'Enquire' }, contact: true },
];
const breadcrumb = { ru: '/ ретриты', en: '/ retreats' };
const footer = {
  variant: 'simple' as const,
  copyright: { ru: '© 2026, Anjoy Space', en: '© 2026, Anjoy Space' },
  links: [
    { label: { ru: 'Все ретриты', en: 'All Retreats' }, href: '/#retreats' },
    { label: { ru: 'На главную', en: 'Home' }, href: '/' },
  ],
};

// Structured data: model each retreat as a TouristTrip (offer/price + itinerary)
// plus an FAQPage when the retreat has questions — both eligible for rich results.
const SITE = 'https://anjoy.space';
const retreatUrl = `${SITE}/retreats/${retreat.id}/`;
const priceRaw = pick(d.price, 'en');
const priceCurrency = priceRaw.includes('₽') ? 'RUB' : priceRaw.includes('€') ? 'EUR' : priceRaw.includes('$') ? 'USD' : undefined;
const priceValue = Number(priceRaw.replace(/[^\d.]/g, '')) || undefined;
const heroImage = d.photos?.[0]?.src ? `${SITE}${d.photos[0].src}` : undefined;

const tripLd = {
  '@type': 'TouristTrip',
  '@id': `${retreatUrl}#trip`,
  name: pick(d.title),
  description: pick(d.summary),
  url: retreatUrl,
  touristType: 'Yoga retreat',
  provider: { '@type': 'Organization', name: 'Anjoy Space', url: `${SITE}/` },
  ...(heroImage ? { image: heroImage } : {}),
  ...(d.itinerary?.length
    ? {
        itinerary: {
          '@type': 'ItemList',
          itemListElement: d.itinerary.map((s, i) => ({ '@type': 'ListItem', position: i + 1, name: pick(s.title) })),
        },
      }
    : {}),
  ...(priceValue && priceCurrency
    ? { offers: { '@type': 'Offer', price: priceValue, priceCurrency, availability: 'https://schema.org/InStock', url: retreatUrl } }
    : {}),
};
const faqLd = d.faq?.length
  ? {
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: pick(f.q),
        acceptedAnswer: { '@type': 'Answer', text: pick(f.a) },
      })),
    }
  : null;
const retreatLd = { '@context': 'https://schema.org', '@graph': [tripLd, ...(faqLd ? [faqLd] : [])] };
---

<BaseLayout
  title={`${pick(d.title)} — Anjoy Space`}
  description={pick(d.summary)}
  pageClass="page-retreat"
  nav={{ breadcrumb, navLinks, menuLinks }}
  footer={footer}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(retreatLd)} slot="head" />
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <T value={d.heroEyebrow} tag="p" class="eyebrow" />
      <span class={`retreat-tag tag-${d.tagStyle}`}><T value={d.tag} /></span>
      <T value={d.title} tag="h1" />
      <div class="retreat-meta">
        <span>📍 <T value={d.location} /></span>
        <span>⏱ <T value={d.days} /></span>
        <span>👥 <T value={d.participants} /></span>
      </div>
      <div class="retreat-price">
        {d.priceFrom && (
          <sup><span data-lang="ru">от</span><span data-lang="en">from</span></sup>
        )} <T value={d.price} />
      </div>
      {d.intro && <T value={d.intro} tag="p" class="lede" />}
      <div>
        <a href="#contact" class="btn-primary" data-contact data-lang="ru">Записаться</a>
        <a href="#contact" class="btn-primary" data-contact data-lang="en">Enquire</a>
        <a href="/#retreats" class="btn-ghost" data-lang="ru">Все ретриты</a>
        <a href="/#retreats" class="btn-ghost" data-lang="en">All Retreats</a>
      </div>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="overview-section">
    <article class="overview-prose reveal">
      {
        d.sections.length > 0 ? (
          d.sections.map((s) => (
            <>
              <T value={s.heading} tag="h2" />
              {s.body.map((p) => (
                <T value={p} tag="p" />
              ))}
            </>
          ))
        ) : (
          <Content />
        )
      }
    </article>
  </section>

  <!-- HIGHLIGHTS -->
  {
    d.highlights.length > 0 && (
      <section>
        <SectionHeader
          eyebrow={{ ru: 'Что вас ждёт', en: 'Highlights' }}
          title={{ ru: 'Что будем практиковать', en: "What you'll practice" }}
        />
        <div class="highlights-grid">
          {d.highlights.map((h) => (
            <div class="highlight-card">
              <T value={h} />
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- SPACES / WHAT AWAITS YOU -->
  {
    d.spaces.length > 0 && (
      <section class="spaces-section">
        <SectionHeader
          eyebrow={{ ru: 'Пространство', en: 'The space' }}
          title={{ ru: 'Дом и территория', en: 'The house & grounds' }}
        />
        <div class="spaces-grid">
          {d.spaces.map((s) => (
            <div class="space-card reveal">
              {s.image && (
                <div class="space-img">
                  <img src={s.image} alt="" loading="lazy" />
                </div>
              )}
              <div class="space-body">
                <T value={s.title} tag="h3" />
                <T value={s.body} tag="p" />
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- ITINERARY -->
  {
    d.itinerary.length > 0 && (
      <section class="itinerary-section">
        <SectionHeader
          eyebrow={{ ru: 'Программа', en: 'The arc' }}
          title={{ ru: 'Подробное расписание', en: 'A typical journey' }}
        />
        <div class="itinerary-list">
          {d.itinerary.map((it) => (
            <div class="itinerary-item reveal">
              <T value={it.label} tag="span" class="itinerary-label" />
              <div>
                <T value={it.title} tag="h3" />
                <T value={it.body} tag="p" />
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- FAQ -->
  {
    d.faq.length > 0 && (
      <section class="faq-section">
        <SectionHeader
          eyebrow={{ ru: 'Вопросы', en: 'FAQ' }}
          title={{ ru: 'Частые вопросы', en: 'Common questions' }}
        />
        <div class="faq-list">
          {d.faq.map((f) => (
            <div class="faq-item reveal">
              <T value={f.q} tag="h3" />
              <T value={f.a} tag="p" />
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- REVIEWS -->
  {
    reviewItems.length > 0 && (
      <section class="reviews-section">
        <SectionHeader
          eyebrow={{ ru: 'Отзывы', en: 'Reviews' }}
          title={{ ru: 'Как изменилась жизнь после ретрита', en: 'Life after the retreat' }}
        />
        <MediaCarousel items={reviewItems} variant="review" />
      </section>
    )
  }

  <!-- GALLERY -->
  {
    photoItems.length > 0 ? (
      <section class="gallery-strip">
        <SectionHeader
          eyebrow={{ ru: 'Как это было', en: 'Gallery' }}
          title={{ ru: 'Йога-дача и Плещеево озеро', en: 'The Yoga-dacha & Lake Pleshcheyevo' }}
        />
        <MediaCarousel items={photoItems} variant="photo" />
      </section>
    ) : (
      d.gallery.length > 0 && (
        <section class="gallery-strip">
          <div class="gallery-grid">
            {d.gallery.map((g) => (
              <div class={`gallery-tile ${g.variant} reveal`}>
                <div class="gallery-symbol">{g.symbol}</div>
              </div>
            ))}
          </div>
        </section>
      )
    )
  }

  <!-- CTA -->
  <div class="cta-band" id="contact">
    <T
      value={d.ctaTitle ?? { ru: 'Готовы присоединиться к ретриту?', en: 'Ready to join this retreat?' }}
      tag="h2"
    />
    <T
      value={d.ctaBody ?? {
        ru: 'Количество мест ограничено, они быстро разбираются. Напишите нам — мы ответим в течение 24 часов и поможем подобрать подходящий вариант.',
        en: "Spots are limited and fill quickly. Reach out and we'll reply within 24 hours to help you find the right fit.",
      }}
      tag="p"
    />
    <a href="#contact" class="btn-primary" data-contact data-lang="ru">Записаться</a>
    <a href="#contact" class="btn-primary" data-contact data-lang="en">Enquire</a>
  </div>
</BaseLayout>
