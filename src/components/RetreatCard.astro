---
import type { Localized } from '../lib/i18n';
import T from './T.astro';

interface Props {
  href: string;
  tag: Localized;
  tagStyle: 'upcoming' | 'intensive' | 'journey';
  title: Localized;
  location: Localized;
  days: Localized;
  participants: Localized;
  price: Localized;
  priceFrom?: boolean;
  summary: Localized;
}

const { href, tag, tagStyle, title, location, days, participants, price, priceFrom = true, summary } =
  Astro.props;
---

<a href={href} class="retreat-card reveal">
  <span class={`retreat-tag tag-${tagStyle}`}><T value={tag} /></span>
  <T value={title} tag="h3" />
  <div class="retreat-meta">
    <span>📍 <T value={location} /></span>
    <span>⏱ <T value={days} /></span>
    <span>👥 <T value={participants} /></span>
  </div>
  <T value={summary} tag="p" />
  <div class="retreat-price">
    {priceFrom && (
      <sup><span data-lang="ru">от</span><span data-lang="en">from</span></sup>
    )} <T value={price} />
  </div>
  <span class="btn-small"><span data-lang="ru">Подробнее →</span><span data-lang="en">View Retreat →</span></span>
</a>
