---
import type { Localized } from '../lib/i18n';
import T from './T.astro';

interface Props {
  variant: string; // gimg-1 … gimg-8
  symbol: string;
  caption: Localized;
}

const { variant, symbol, caption } = Astro.props;
---

<div class="gallery-item reveal">
  <div class="gallery-item-inner">
    <div class={`gallery-img gimg ${variant}`}>
      <div class="gallery-symbol">{symbol}</div>
    </div>
    <div class="gallery-overlay"><T value={caption} tag="span" /></div>
  </div>
</div>
