---
interface Props {
  variant?: 'hero' | 'about';
}
const { variant = 'hero' } = Astro.props;

const outerPetals = [0, 30, 60, 90, 120, 150, 180, 210, 240, 270, 300, 330];
const petalFill = ['#C9A96E', '#8B6F9E', '#3D6B5E'];
const petalOpacity = [0.4, 0.35, 0.4];
const innerPetals = [0, 45, 90, 135, 180, 225, 270, 315];
const flower = [
  [100, 100], [120, 100], [80, 100], [110, 82.7], [90, 82.7], [110, 117.3], [90, 117.3],
];
---

{
  variant === 'hero' ? (
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="100" cy="100" r="90" stroke="#C9A96E" stroke-width="0.5" opacity="0.3" />
      <circle cx="100" cy="100" r="75" stroke="#C9A96E" stroke-width="0.5" opacity="0.25" />
      <g opacity="0.6">
        {outerPetals.map((deg, i) => (
          <ellipse
            cx="100"
            cy="30"
            rx="8"
            ry="20"
            fill={petalFill[i % 3]}
            opacity={petalOpacity[i % 3]}
            transform={`rotate(${deg} 100 100)`}
          />
        ))}
      </g>
      <g opacity="0.8">
        {innerPetals.map((deg) => (
          <ellipse
            cx="100"
            cy="55"
            rx="5"
            ry="14"
            fill="#E2C98A"
            opacity="0.5"
            transform={`rotate(${deg} 100 100)`}
          />
        ))}
      </g>
      <g stroke="#C9A96E" stroke-width="0.4" opacity="0.35" fill="none">
        {flower.map(([cx, cy]) => (
          <circle cx={cx} cy={cy} r="20" />
        ))}
      </g>
      <circle cx="100" cy="100" r="4" fill="#E2C98A" opacity="0.9" />
      <circle cx="100" cy="100" r="1.5" fill="#fff" opacity="0.8" />
    </svg>
  ) : (
    <svg viewBox="0 0 200 200" fill="none">
      <circle cx="100" cy="100" r="95" stroke="#C9A96E" stroke-width="0.4" />
      <circle cx="100" cy="100" r="70" stroke="#C9A96E" stroke-width="0.4" />
      <circle cx="100" cy="100" r="45" stroke="#C9A96E" stroke-width="0.4" />
      <g stroke="#C9A96E" stroke-width="0.3" fill="none">
        {flower.map(([cx, cy]) => (
          <circle cx={cx} cy={cy} r="20" />
        ))}
      </g>
      <circle cx="100" cy="100" r="5" fill="#C9A96E" opacity="0.8" />
    </svg>
  )
}
