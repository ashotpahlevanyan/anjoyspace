---
/**
 * Social share row. Share links are built from the current URL at runtime.
 * On devices with the Web Share API (mobile) a native "Share" button appears,
 * which opens the OS share sheet — including Instagram, Telegram, and more.
 * Explicit Telegram / WhatsApp / X / Facebook / Copy-link buttons are the
 * fallback (Instagram has no web-share URL, so Copy covers it on desktop).
 */
---

<div class="social-share" data-share>
  <span class="share-label" data-lang="ru">Поделиться</span><span class="share-label" data-lang="en">Share</span>

  <button type="button" class="share-btn share-native" data-share-native hidden aria-label="Share">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="18" cy="5" r="2.5"></circle><circle cx="6" cy="12" r="2.5"></circle><circle cx="18" cy="19" r="2.5"></circle>
      <path d="M8.2 10.9l7.6-4.3M8.2 13.1l7.6 4.3"></path>
    </svg>
  </button>

  <a class="share-btn" data-net="telegram" target="_blank" rel="noopener" aria-label="Telegram" href="#">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M21.9 4.3l-3 14.2c-.2 1-.8 1.2-1.7.8l-4.6-3.4-2.2 2.1c-.2.2-.5.5-.9.5l.3-4.6 8.4-7.6c.4-.3-.1-.5-.6-.2L7.4 13.1l-4.5-1.4c-1-.3-1-.9.2-1.4L20.5 3c.8-.3 1.6.2 1.4 1.3z"></path></svg>
  </a>

  <a class="share-btn" data-net="whatsapp" target="_blank" rel="noopener" aria-label="WhatsApp" href="#">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.5 8.5 0 0 1-12.7 7.4L3 21l2.1-5.3A8.5 8.5 0 1 1 21 11.5z"></path><path d="M8.5 9.5c0 3 2 5 5 5.5"></path></svg>
  </a>

  <a class="share-btn" data-net="x" target="_blank" rel="noopener" aria-label="X" href="#">
    <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M18.9 2H22l-7.2 8.2L23 22h-6.6l-5.2-6.8L5.3 22H2.2l7.7-8.8L1.5 2h6.8l4.7 6.2L18.9 2zm-2.3 18h1.8L7.5 3.8H5.6L16.6 20z"></path></svg>
  </a>

  <a class="share-btn" data-net="facebook" target="_blank" rel="noopener" aria-label="Facebook" href="#">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M14 8.5h2.2V5.4H14c-2 0-3.3 1.3-3.3 3.3v1.6H8.7v3.1h2v6.6h3.1v-6.6h2.2l.4-3.1h-2.6V8.9c0-.3.1-.4.4-.4z"></path></svg>
  </a>

  <button type="button" class="share-btn share-copy" data-share-copy aria-label="Copy link">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.1 0l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1"></path><path d="M14 11a5 5 0 0 0-7.1 0l-2 2a5 5 0 0 0 7.1 7.1l1.1-1.1"></path></svg>
    <span class="share-copied" data-lang="ru">Скопировано</span><span class="share-copied" data-lang="en">Copied</span>
  </button>
</div>

<script>
  document.querySelectorAll('[data-share]').forEach((el) => {
    const url = window.location.href;
    const title = document.title;
    const e = encodeURIComponent;
    const links: Record<string, string> = {
      telegram: `https://t.me/share/url?url=${e(url)}&text=${e(title)}`,
      whatsapp: `https://wa.me/?text=${e(title + ' ' + url)}`,
      x: `https://twitter.com/intent/tweet?url=${e(url)}&text=${e(title)}`,
      facebook: `https://www.facebook.com/sharer/sharer.php?u=${e(url)}`,
    };
    el.querySelectorAll<HTMLAnchorElement>('a[data-net]').forEach((a) => {
      const net = a.getAttribute('data-net');
      if (net && links[net]) a.href = links[net];
    });

    const nativeBtn = el.querySelector<HTMLButtonElement>('[data-share-native]');
    if (nativeBtn && typeof navigator.share === 'function') {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', () => {
        navigator.share({ title, url }).catch(() => {});
      });
    }

    const copyBtn = el.querySelector<HTMLButtonElement>('[data-share-copy]');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url);
          copyBtn.classList.add('copied');
          setTimeout(() => copyBtn.classList.remove('copied'), 1800);
        } catch {
          /* clipboard unavailable */
        }
      });
    }
  });
</script>
